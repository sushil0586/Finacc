FINACC_BANK_RECO_META_PATH=/api/bank-reconciliation/meta/
FINACC_BANK_RECO_SESSIONS_PATH=/api/bank-reconciliation/sessions/
FINACC_SALES_INVOICE_CONFIRM_SUFFIX=/confirm/
FINACC_SALES_INVOICE_POST_SUFFIX=/post/
