# Local backend host
LOCUST_HOST=http://127.0.0.1:8000

# Fill in a valid active user email and password from your local environment.
# Example active users were discovered from the local DB, but keep the final
# credential choice limited to an account you control and that has access to
# the target entity scope.
FINACC_USER_EMAIL=
FINACC_USER_PASSWORD=

# Discovered local scope that exists in the current DB
FINACC_ENTITY_ID=5
FINACC_ENTITY_FIN_ID=3
FINACC_SUBENTITY_ID=3

# Endpoint paths
FINACC_LOGIN_PATH=/api/auth/login
FINACC_ME_PATH=/api/auth/me
FINACC_SALES_INVOICE_PATH=/api/sales/invoices/
FINACC_SALES_INVOICE_LOOKUP_PATH=/api/sales/invoices/lookup/
FINACC_SALES_SERVICE_INVOICE_LOOKUP_PATH=/api/sales/service-invoices/lookup/
FINACC_SALES_SETTINGS_PATH=/api/sales/settings/
FINACC_PAYABLES_META_PATH=/api/reports/payables/meta/
