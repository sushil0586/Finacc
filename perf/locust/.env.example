# Host can also be passed via --host
LOCUST_HOST=http://127.0.0.1:8000

# Credentials
FINACC_USER_EMAIL=qa.user@example.com
FINACC_USER_PASSWORD=change-me

# Scope (required by many Finacc endpoints)
FINACC_ENTITY_ID=1
FINACC_ENTITY_FIN_ID=1
FINACC_SUBENTITY_ID=

# Endpoint paths (relative to host)
FINACC_LOGIN_PATH=/api/auth/login
FINACC_ME_PATH=/api/auth/me
FINACC_SALES_INVOICE_PATH=/api/sales/invoices/
FINACC_SALES_SETTINGS_PATH=/api/sales/settings/
FINACC_SALES_INVOICE_CONFIRM_SUFFIX=/confirm/
FINACC_SALES_INVOICE_POST_SUFFIX=/post/
FINACC_SALES_INVOICE_REVERSE_SUFFIX=/reverse/

# Keep false unless using dedicated test fixtures
FINACC_ENABLE_WRITE_TESTS=false
FINACC_ENABLE_LIFECYCLE_TESTS=false
