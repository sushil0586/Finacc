# ============================================================
# Django Core
# ============================================================
SECRET_KEY=your-secret-key-here
DEBUG=False
RBAC_DEV_ALLOW_ALL_ACCESS=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ============================================================
# CORS
# ============================================================
# Must be False when CORS_ALLOW_CREDENTIALS=True — browsers block wildcard + credentials
CORS_ORIGIN_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_NAME=FA
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=

# ============================================================
# Email
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
EMAIL_TIMEOUT=20

# ============================================================
# GST / e-Invoice / e-Way Bill
# ============================================================
EINVOICE_PROVIDER=whitebooks
EWAY_PROVIDER=whitebooks
MASTERGST_ENV=PRODUCTION
MASTERGST_BASE_URL=https://api.mastergst.com
MASTERGST_IP_ADDRESS=your-server-public-ip
WHITEBOOKS_BASE_URL=https://api.whitebooks.in
ALLOW_RELAXED_GSTIN_FOR_SANDBOX=False
FINANCIAL_ACCOUNT_ALLOW_RELAXED_GSTIN=False

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
