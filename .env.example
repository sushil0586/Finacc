# ============================================================
# Django Core
# ============================================================
SECRET_KEY=your-secret-key-here
DEBUG=False
RBAC_DEV_ALLOW_ALL_ACCESS=False
ALLOWED_HOSTS=staging.yourdomain.com,localhost,127.0.0.1

# ============================================================
# CORS / CSRF
# ============================================================
# Must be False when CORS_ALLOW_CREDENTIALS=True - browsers block wildcard + credentials
CORS_ORIGIN_ALLOW_ALL=False
CORS_ALLOWED_ORIGINS=https://staging.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://staging.yourdomain.com

# ============================================================
# Reverse Proxy / HTTPS
# ============================================================
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PORT=True
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ============================================================
# Database (PostgreSQL)
# ============================================================
DB_NAME=FA
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=5432

# ============================================================
# File Storage (Phased: Local -> S3)
# ============================================================
# local: store in EC2/EBS at MEDIA_ROOT
# s3: store in Amazon S3 via django-storages
FILE_STORAGE_BACKEND=local

# Required when FILE_STORAGE_BACKEND=s3
AWS_STORAGE_BUCKET_NAME=finacc-stage-files
AWS_S3_REGION_NAME=ap-south-1

# Optional: leave blank when using EC2 IAM role
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional
AWS_S3_CUSTOM_DOMAIN=
AWS_MEDIA_LOCATION=
AWS_QUERYSTRING_AUTH=True

# ============================================================
# Cache (Phase 3: meta endpoint caching)
# ============================================================
# locmem (default) or redis
CACHE_BACKEND=locmem
# locmem location name OR redis URL (redis://host:6379/1)
CACHE_LOCATION=finacc-cache
CACHE_TIMEOUT_SECONDS=300

META_CACHE_ENABLED=True
META_CACHE_TTL_SECONDS=300
META_CACHE_FORM_TTL_SECONDS=600
META_CACHE_SETTINGS_TTL_SECONDS=300
META_CACHE_VERSION=1
META_CACHE_OBSERVABILITY_ENABLED=False
META_CACHE_LOG_LEVEL=INFO

# ============================================================
# Email
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
EMAIL_TIMEOUT=20

# ============================================================
# GST / e-Invoice / e-Way Bill
# ============================================================
EINVOICE_PROVIDER=whitebooks
EWAY_PROVIDER=whitebooks
MASTERGST_ENV=PRODUCTION
MASTERGST_BASE_URL=https://api.mastergst.com
MASTERGST_IP_ADDRESS=your-server-public-ip
WHITEBOOKS_BASE_URL=https://api.whitebooks.in
ALLOW_RELAXED_GSTIN_FOR_SANDBOX=False
FINANCIAL_ACCOUNT_ALLOW_RELAXED_GSTIN=False

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
